{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true,
        "types": []
    },
    "include": [
        "src/global.d.ts",
        "src/js/message-types.js",
        "src/js/messaging.js",
        "src/js/signaling.js",
        "src/js/host-peers.js"
    ]
}
